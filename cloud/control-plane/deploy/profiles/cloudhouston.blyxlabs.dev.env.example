# Copiar a cloudhouston.blyxlabs.dev.env (gitignored). NO commitear el .env real.
# Repo público: rotar cualquier secreto que haya estado en git.

SUPABASE_DB_PASSWORD=your-supabase-database-password
DATABASE_URL=postgresql://postgres.PROJECT_REF:your-supabase-database-password@POOL_HOST:5432/postgres?sslmode=require

HOUSTON_CLOUD_AUTH=local
HOUSTON_CLOUD_TOKEN=hst_GENERATE_WITH_openssl_rand_hex_32
HOUSTON_CLOUD_LOCAL_USER_ID=00000000-0000-0000-0000-000000000001
HOUSTON_CLOUD_LOCAL_EMAIL=you@example.com
HOUSTON_CLOUD_DOMAIN=cloudhouston.blyxlabs.dev
HOUSTON_CLOUD_RUNTIME=k8s
HOUSTON_ENGINE_IMAGE=houston/engine:dev
HOUSTON_CLOUD_CORS_ORIGINS=*

HOUSTON_CLOUD_BASE=https://cloudhouston.blyxlabs.dev

# Solo app desktop (Mac). No incluir en Secret de Kubernetes.
VITE_HOUSTON_CLOUD_BASE=https://cloudhouston.blyxlabs.dev
VITE_HOUSTON_CLOUD_TOKEN=hst_SAME_AS_HOUSTON_CLOUD_TOKEN
