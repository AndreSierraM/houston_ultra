# Copiar a local.env (gitignored). Password debe coincidir con postgres.yaml del overlay local.

DATABASE_URL=postgresql://houston:change-me-local-dev@postgres:5432/houston_cloud

HOUSTON_CLOUD_AUTH=local
HOUSTON_CLOUD_TOKEN=hst_GENERATE_WITH_scripts/generate-cloud-token.sh
HOUSTON_CLOUD_LOCAL_USER_ID=00000000-0000-0000-0000-000000000001
HOUSTON_CLOUD_LOCAL_EMAIL=dev@local.test
HOUSTON_CLOUD_RUNTIME=k8s
HOUSTON_ENGINE_IMAGE=houston/engine:dev
HOUSTON_CLOUD_CORS_ORIGINS=*

# Solo app desktop (Mac). No incluir en Secret de Kubernetes.
VITE_HOUSTON_CLOUD_BASE=http://127.0.0.1:8788
VITE_HOUSTON_CLOUD_TOKEN=hst_SAME_AS_HOUSTON_CLOUD_TOKEN
